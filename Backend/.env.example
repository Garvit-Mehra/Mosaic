# === Mosaic Backend Environment ===

# --- Required ---
TAVILY_API_KEY=your_tavily_api_key

# --- Authentication ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_this
USER_USERNAME=user
USER_PASSWORD=change_this
JWT_SECRET=generate_with_python_c_import_secrets_print_secrets_token_hex_32
TOKEN_EXPIRE_HOURS=24
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- LLM Provider ---
# Options: ollama, openai, compatible (for vLLM/TGI/Groq/Together)
LLM_PROVIDER=ollama
LLM_MODEL=llama3.2
# LLM_BASE_URL=http://localhost:11434  # default for ollama
# LLM_API_KEY=sk-...                    # needed for openai/compatible
# LLM_TEMPERATURE=0.7

# --- Database ---
# SQLite (local dev):
# DATABASE_URL=sqlite:///conversations.db
# PostgreSQL (production):
# DATABASE_URL=postgresql://mosaic:password@localhost:5432/mosaic

# --- Redis (optional — for rate limiting + future caching) ---
# REDIS_URL=redis://localhost:6379/0

# --- Security ---
ENVIRONMENT=development
LOGIN_RATE_LIMIT=5
LOGIN_RATE_WINDOW=300
ALLOWED_ORIGINS=*
# For production: ALLOWED_ORIGINS=https://yourdomain.com

# --- Logging ---
LOG_LEVEL=INFO
MAX_HISTORY_MESSAGES=10

# --- MCP Servers (JSON array, optional override) ---
# MCP_SERVERS=[{"name":"my_server","description":"...","url":"http://localhost:9000/sse"}]
